{
    "$schema": "https://turborepo.org/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
        "lint": {},
        "test": {
            "outputs": ["coverage/**"]
        }
    }
}