# Server
NODE_ENV=development
PORT=3000

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis cache
REDIS_URL=redis://localhost:6379

# JWT Secret key, generation: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_64_chars_minimun_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=different_64_chars_minimum_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ImageKit
IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_PRIVATE_KEY=private_...
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/ID

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/media/youtube/callback
YOUTUBE_REFRESH_TOKEN=   # set once after first OAuth authorization

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@domain.com

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# Security
ALLOWED_ORIGINS=http://localhost:5173
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100